rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ASSISTLINK SECURITY ARCHITECTURE
     * 
     * Core Philosophy:
     * This ruleset implements an Organization-Based Multi-tenancy model. Access is strictly 
     * partitioned by `organizationId`. User profiles are keyed by email address as requested.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    /** @description Checks if the user's email matches the provided userEmail. */
    function isOwner(userEmail) {
      return isSignedIn() && request.auth.token.email == userEmail;
    }

    /** @description Retrieves the user's profile data for organization verification. */
    function getUserData() {
      // Profiles are keyed by email address
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
    }

    /** @description Verifies if the authenticated user belongs to a specific organization. */
    function isOrgMember(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId;
    }

    /** @description Verifies if the authenticated user is an admin of their organization. */
    function isOrgAdmin(orgId) {
      return isOrgMember(orgId) && getUserData().role == 'admin';
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User profiles. 
     * Profiles are keyed by email. Members can see others in the same org.
     */
    match /users/{userEmail} {
      allow get: if isOwner(userEmail) || isOrgMember(resource.data.organizationId);
      
      // Allow listing users if filtering by your own organizationId
      allow list: if isSignedIn() && (
        isOwner(userEmail) || 
        getUserData().organizationId == resource.data.organizationId
      );

      allow create: if isOwner(userEmail);
      allow update: if isOwner(userEmail) || isOrgAdmin(resource.data.organizationId);
      allow delete: if isOrgAdmin(resource.data.organizationId);

      match /emailNotificationSettings/{settingId} {
        allow get, list, create, update, delete: if isOwner(userEmail);
      }
    }

    /**
     * @description Top-level organization document. Access restricted to members.
     */
    match /organizations/{organizationId} {
      allow get, list: if isOrgMember(organizationId);
      allow create: if isSignedIn();
      allow update: if isOrgMember(organizationId);
      allow delete: if isOrgAdmin(organizationId);

      match /chatWidgetConfigurations/{widgetId} {
        allow get, list: if isOrgMember(organizationId);
        allow create, update, delete: if isOrgMember(organizationId);
      }

      match /customers/{customerId} {
        allow get, list: if isOrgMember(organizationId);
        allow create: if isSignedIn() && request.resource.data.organizationId == organizationId;
        allow update, delete: if isOrgMember(organizationId);
      }

      match /chatSessions/{sessionId} {
        allow get, list: if isOrgMember(organizationId);
        allow create: if isSignedIn() && request.resource.data.organizationId == organizationId;
        allow update, delete: if isOrgMember(organizationId);

        match /chatMessages/{messageId} {
          allow get, list: if isOrgMember(organizationId);
          allow create: if isSignedIn() && request.resource.data.organizationId == organizationId;
          allow update, delete: if isOrgMember(organizationId);
        }
      }

      match /agentSmartReplies/{replyId} {
        allow get, list, create, update, delete: if isOrgMember(organizationId);
      }

      match /emailNotificationSettings/{settingId} {
        allow get, list, create, update, delete: if isOrgMember(organizationId);
      }
    }

    match /globalAgentSmartReplies/{replyId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }
  }
}
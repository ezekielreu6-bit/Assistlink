rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========
    function isSignedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function getUserData() {
      let userDoc = get(/databases/\( (database)/documents/users/ \)(request.auth.token.email));
      return userDoc.exists ? userDoc.data : null;
    }

    function isOrgMember(orgId) {
      let user = getUserData();
      return isSignedIn() && user != null && user.organizationId == orgId;
    }

    function isOrgAdmin(orgId) {
      let user = getUserData();
      return isOrgMember(orgId) && user.role == 'admin';
    }

    // ========== USERS ==========
    match /users/{userEmail} {
      allow read, write: if isSignedIn() && request.auth.token.email == userEmail;
    }

    // ========== ORGANIZATIONS ==========
    match /organizations/{orgId} {
      // Dashboard access for org members
      allow read, write: if isOrgMember(orgId);

      // Widget config (public read for widget, write for members)
      match /chatWidgetConfigurations/{configId} {
        allow read: if true;
        allow write: if isOrgMember(orgId);
      }

      // ========== CHAT SESSIONS (Widget + Dashboard) ==========
      match /chatSessions/{sessionId} {
        // Public can create sessions (widget)
        allow create: if true;
        
        // Public can read their own session (widget)
        allow get: if true;
        
        // Org members can list, update, delete all sessions
        allow list, update, delete: if isOrgMember(orgId);

        // ========== CHAT MESSAGES ==========
        match /chatMessages/{messageId} {
          // Public can create and read messages (widget)
          allow create, get, list: if true;
          
          // Org members can update/delete
          allow update, delete: if isOrgMember(orgId);
        }
      }

      match /customers/{customerId} {
        allow read, write: if isOrgMember(orgId);
      }

      match /agentSmartReplies/{replyId} {
        allow read, write: if isOrgMember(orgId);
      }
    }

    match /globalAgentSmartReplies/{replyId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}